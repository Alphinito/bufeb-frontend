<style>
	.search-section {
        position: relative;
        display: grid;
        align-items: center;
        justify-items: center;
        height: 60vh;
        width: 100%;
        .search-icons-container {
            justify-content: center;
            background-color: brown;
            overflow: hidden;
            position: absolute;
            display: flex;
            flex-direction: column;
            gap: var(--spacing-md);
            width: 100%;
            height: 60vh;
            .search-icon {
                border: var(--border-width-thin) solid var(--secondary-color);
                height: min-content;
                width: min-content;
                opacity: 0.3;
                padding: var(--spacing-sm) var(--spacing-md);
                &:hover {
                    opacity: 1;
                    transition: opacity 0.5s ease-in-out;
                }
                .search-icon-image {
                    object-fit: cover;
                    width: var(--img-lg);
                    height: auto;
                }
            }
        }
        .search-bar-container {
            position: relative;
            .search-bar-input {

            }
        }
    }
</style>

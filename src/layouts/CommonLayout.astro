---
import '../styles/variables.css';

interface Props {
    title?: string;
}
const { title = "Bufeb" } = Astro.props;
---
<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        {Astro.slots.header && (
            <header>
                <slot name="header" />
            </header>
        )}
        <main>
            <slot name="body" />
        </main>
        {Astro.slots.footer && (
            <footer>
                <slot name="footer" />
            </footer>
        )}
    </body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

    main {
        display: flex;
        gap: 1rem;
        flex-direction: column;
        align-items: center;
    }
</style>